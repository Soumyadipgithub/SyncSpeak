{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sync Speak",
  "version": "../package.json",
  "identifier": "com.syncspeak.app",
  "build": {
    "beforeDevCommand": "npx vite",
    "beforeBuildCommand": "npx vite build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SyncSpeak",
        "width": 1000,
        "height": 720,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/syncspeaker-sidecar"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Soumyadipgithub/SyncSpeak/releases/latest/download/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU1OEMxQjQ0MEU2RUMxMjgKUldRb3dXNE9SQnVNVlJ6bzBZQWx1a1BGeVA4dlJRYlRiWlQ2YmZMa09WMUI3WUFEeDFCUCtrcm8K"
    },
    "shell": {}
  }
}
