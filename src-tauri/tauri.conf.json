{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SyncSpeak",
  "version": "3.0.0",
  "identifier": "com.syncspeak.app",
  "build": {
    "beforeDevCommand": "npx vite",
    "beforeBuildCommand": "npx vite build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SyncSpeak",
        "width": 1000,
        "height": 720,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/syncspeaker-sidecar"
    ]
  },
  "plugins": {
    "shell": {}
  }
}
