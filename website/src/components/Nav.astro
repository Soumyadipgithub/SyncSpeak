---
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

const links = [
  { href: '/features', label: 'Features' },
  { href: '/how-it-works', label: 'How it works' },
  { href: '/developers', label: 'Developers' },
  { href: '/docs', label: 'Docs' },
  { href: '/faq', label: 'FAQ' },
];
---

<header class="nav-wrap">
  <nav class="nav glass-card" aria-label="Primary">
    <a href="/" class="brand" aria-label="Sync Speak home">
      <img src="/logo2.png" alt="" class="logo-img" aria-hidden="true" />
      <span class="brand-text">Sync Speak</span>
    </a>

    <ul class="links" role="list">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['link', { active: isActive(link.href) }]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a href="/download" class="nav-cta gradient-btn">Download</a>

    <button
      class="menu-btn"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
      data-menu-toggle
    >
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
    </button>
  </nav>
</header>

<div
  id="mobile-drawer"
  class="drawer"
  data-drawer
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
>
  <div class="drawer-backdrop" data-drawer-close></div>
  <div class="drawer-panel glass-card">
    <ul class="drawer-links" role="list">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['drawer-link', { active: isActive(link.href) }]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a href="/download" class="drawer-link drawer-cta">Download</a>
      </li>
    </ul>
  </div>
</div>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const drawer = document.querySelector<HTMLElement>('[data-drawer]');
  const backdrop = document.querySelector<HTMLElement>('[data-drawer-close]');

  const setOpen = (open: boolean) => {
    if (!btn || !drawer) return;
    btn.setAttribute('aria-expanded', String(open));
    drawer.setAttribute('aria-hidden', String(!open));
    drawer.dataset.open = String(open);
    document.body.style.overflow = open ? 'hidden' : '';
  };

  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    setOpen(!open);
  });

  backdrop?.addEventListener('click', () => setOpen(false));

  drawer?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => setOpen(false))
  );

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>

<style>
  .nav-wrap {
    position: sticky;
    top: var(--space-m);
    z-index: 50;
    padding: 0 var(--gutter);
    margin-top: var(--space-m);
  }

  .nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-s) var(--space-m) var(--space-s) var(--space-l);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-l);
    border-radius: var(--radius-pill);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-s);
    font-weight: 700;
    letter-spacing: -0.02em;
    min-width: 0;
  }
  .brand:hover { color: var(--vibrant-primary); }

  .logo-img {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-s);
    object-fit: cover;
    flex-shrink: 0;
  }

  .brand-text { font-size: 1.0625rem; }

  .links {
    display: flex;
    gap: var(--space-xs);
    list-style: none;
  }

  .link {
    display: inline-block;
    padding: var(--space-s) var(--space-m);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--vibrant-label);
    border-radius: var(--radius-pill);
    transition: var(--liquid-morph);
  }

  .link:hover {
    color: var(--vibrant-primary);
    background: var(--glass-bg);
  }

  .link.active {
    color: var(--vibrant-primary);
    background: var(--segmented-bg);
  }

  .nav-cta {
    padding: var(--space-s) var(--space-l);
    font-size: 0.875rem;
  }

  /* Hamburger button — hidden on desktop */
  .menu-btn {
    display: none;
    width: 44px;
    height: 44px;
    padding: 10px;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: transparent;
    border-radius: var(--radius-pill);
    transition: var(--liquid-morph);
  }
  .menu-btn:hover { background: var(--glass-bg); }
  .menu-bar {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--vibrant-primary);
    border-radius: 2px;
    transition: transform 300ms var(--liquid-morph), opacity 200ms var(--liquid-morph);
    transform-origin: center;
  }
  .menu-btn[aria-expanded='true'] .menu-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .menu-btn[aria-expanded='true'] .menu-bar:nth-child(2) { opacity: 0; }
  .menu-btn[aria-expanded='true'] .menu-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Drawer — only exists on mobile/tablet (display flipped via media query below) */
  .drawer {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
  }
  .drawer[data-open='true'] { pointer-events: auto; }

  .drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    transition: opacity 320ms var(--liquid-morph);
  }
  .drawer[data-open='true'] .drawer-backdrop { opacity: 1; }

  .drawer-panel {
    position: absolute;
    top: var(--space-m);
    right: var(--space-m);
    left: var(--space-m);
    max-width: 420px;
    margin-left: auto;
    padding: var(--space-xl);
    border-radius: var(--radius-xl);
    transform: translateY(-16px) scale(0.98);
    opacity: 0;
    transition: transform 420ms var(--liquid-morph), opacity 320ms var(--liquid-morph);
  }
  .drawer[data-open='true'] .drawer-panel {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .drawer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin-top: var(--space-xl);
  }
  .drawer-link {
    display: block;
    padding: var(--space-m) var(--space-l);
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--vibrant-label);
    border-radius: var(--radius-m);
    transition: var(--liquid-morph);
  }
  .drawer-link:hover { background: var(--glass-bg); color: var(--vibrant-primary); }
  .drawer-link.active {
    background: var(--segmented-bg);
    color: var(--vibrant-primary);
  }
  .drawer-cta {
    margin-top: var(--space-m);
    text-align: center;
    background: linear-gradient(180deg, var(--green) 0%, #28b84d 100%);
    color: #000;
    font-weight: 700;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }
  .drawer-cta:hover { color: #000; background: linear-gradient(180deg, var(--green) 0%, #28b84d 100%); }

  /* Breakpoint: 1024px = collapse nav links → hamburger */
  @media (max-width: 1024px) {
    .links { display: none; }
    .nav-cta { display: none; }
    .menu-btn { display: inline-flex; }
    .drawer { display: block; }
    .nav { padding: var(--space-s) var(--space-s) var(--space-s) var(--space-l); }
  }

  @media (max-width: 640px) {
    .nav { padding: var(--space-xs) var(--space-xs) var(--space-xs) var(--space-m); gap: var(--space-s); }
    .brand-text { font-size: 1rem; }
  }
</style>
