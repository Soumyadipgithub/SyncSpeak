---
const year = new Date().getFullYear();

const columns = [
  {
    title: 'Product',
    links: [
      { href: '/features', label: 'Features' },
      { href: '/how-it-works', label: 'How it works' },
      { href: '/download', label: 'Download' },
      { href: '/faq', label: 'FAQ' },
    ],
  },
  {
    title: 'Developers',
    links: [
      { href: '/developers', label: 'Contribute' },
      { href: '/docs', label: 'Documentation' },
      { href: 'https://github.com/Soumyadipgithub/SyncSpeak', label: 'GitHub', external: true },
      {
        href: 'https://github.com/Soumyadipgithub/SyncSpeak/issues',
        label: 'Report a bug',
        external: true,
      },
    ],
  },
  {
    title: 'Company',
    links: [
      { href: '/privacy', label: 'Privacy' },
      {
        href: 'https://github.com/Soumyadipgithub/SyncSpeak/blob/main/LICENSE',
        label: 'License (MIT)',
        external: true,
      },
      {
        href: 'https://github.com/Soumyadipgithub/SyncSpeak/blob/main/SECURITY.md',
        label: 'Security',
        external: true,
      },
    ],
  },
];
---

<footer class="footer">
  <div class="container">
    <div class="grid">
      <div class="brand-col">
        <div class="brand">
          <span class="logo-dot" aria-hidden="true"></span>
          <span>SyncSpeak</span>
        </div>
        <p class="tagline">
          Real-time Hindi → English for meetings. Local, open-source, fast.
        </p>
      </div>
      {
        columns.map((col) => (
          <div class="col">
            <h4 class="hig-label">{col.title}</h4>
            <ul role="list">
              {col.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    rel={l.external ? 'noopener' : undefined}
                    target={l.external ? '_blank' : undefined}
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="bottom">
      <span>© {year} SyncSpeak. Open-source under MIT.</span>
      <span class="status">
        <span class="pulse" aria-hidden="true"></span> v3 pipeline active
      </span>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--space-4xl);
    padding: var(--space-3xl) 0 var(--space-xl);
    border-top: 1px solid var(--border-glass);
  }

  .grid {
    display: grid;
    grid-template-columns: 1.4fr repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-s);
    font-weight: 700;
    font-size: 1.125rem;
  }

  .logo-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-blue), var(--green));
    box-shadow: 0 0 12px var(--accent-blue);
  }

  .tagline {
    margin-top: var(--space-m);
    max-width: 32ch;
    font-size: 0.9375rem;
  }

  .col ul {
    list-style: none;
    margin-top: var(--space-m);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .col a {
    font-size: 0.9375rem;
    color: var(--vibrant-label);
  }

  .col a:hover { color: var(--vibrant-primary); }

  .bottom {
    margin-top: var(--space-xl);
    padding-top: var(--space-l);
    border-top: 1px solid var(--border-glass);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8125rem;
    color: var(--vibrant-secondary);
    flex-wrap: wrap;
    gap: var(--space-m);
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-s);
  }

  .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  @media (max-width: 820px) {
    .grid { grid-template-columns: 1fr 1fr; }
    .brand-col { grid-column: 1 / -1; }
  }
</style>
