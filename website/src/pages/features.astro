---
import BaseLayout from '../layouts/BaseLayout.astro';
import DownloadButton from '../components/DownloadButton.astro';

const title = 'Features — SyncSpeak';
const description =
  'Everything SyncSpeak does: neural voice activity detection, context-aware translation, sentence-pipelined TTS, virtual-cable audio routing, and a transparent desktop shell.';

const features = [
  {
    icon: '🎙️',
    title: 'Neural Voice Activity Detection',
    body:
      'WebRTC Neural VAD separates speech from silence in 10 ms frames. A 500 ms ' +
      'pre-buffer (5-frame ring) means the first syllable of short Hindi words ' +
      'like "kya", "toh", "haan" is never clipped.',
  },
  {
    icon: '🗣️',
    title: 'Hindi + Hinglish STT',
    body:
      'Sarvam Saarika v2.5 handles code-mixed speech natively — "deployment ho gaya" ' +
      'is transcribed correctly, not normalised into pure Hindi. A correction table ' +
      'catches common phonetic mis-mappings before they reach the LLM.',
  },
  {
    icon: '🧠',
    title: '5-utterance rolling context',
    body:
      'Groq Llama 3.3 70B sees your last five sentences when translating the current ' +
      'one. Pronouns resolve correctly ("use bhej do" → "send it to him"), and ' +
      'running topics maintain continuity across a meeting.',
  },
  {
    icon: '⚡',
    title: 'Sentence-pipelined TTS',
    body:
      'Sarvam Bulbul v3 synthesises English audio one sentence at a time. Playback ' +
      'of sentence N starts while sentence N+1 is still being generated, so end-to-end ' +
      'latency stays under 1.2 seconds even for long replies.',
  },
  {
    icon: '🎧',
    title: 'Virtual-cable routing',
    body:
      'VB-Cable\'s virtual microphone takes the translated audio and feeds it into any ' +
      'application that accepts a mic: Google Meet, Zoom, Teams, Discord, Slack huddles, ' +
      'Whereby, Gather. Zero plugin required in the meeting app.',
  },
  {
    icon: '🛑',
    title: 'Self-talk prevention',
    body:
      'A _tts_active flag blocks the microphone while SyncSpeak is speaking English, ' +
      'so the translated output is never re-captured and re-translated back to Hindi. ' +
      'VAD state resets cleanly between utterances.',
  },
  {
    icon: '🔁',
    title: 'Device resilience',
    body:
      'If your selected mic is held by Teams or Zoom, SyncSpeak falls back to the system ' +
      'default mic. WASAPI is re-initialised before every stream open, eliminating the ' +
      'classic -9985 stale device error on Windows.',
  },
  {
    icon: '🪟',
    title: 'Liquid Glass transparency',
    body:
      'A native Tauri v2 shell with genuine desktop transparency — the app is a frosted ' +
      'lens over your screen, not a windowed chrome. Minimal CPU, no Electron overhead.',
  },
  {
    icon: '🔒',
    title: 'Keys stay on your machine',
    body:
      'Sarvam and Groq API keys are entered in the Settings modal and saved to a local ' +
      'config file. Nothing is uploaded to SyncSpeak servers. There are no SyncSpeak ' +
      'servers.',
  },
  {
    icon: '📜',
    title: 'Conversation history',
    body:
      'Every translated utterance is saved locally so you can scroll back through a ' +
      'meeting. History is yours, on disk, clearable at will.',
  },
  {
    icon: '🎛️',
    title: 'Voice + prosody control',
    body:
      'Choose between multiple Bulbul voices and tune speech rate. The translation tone ' +
      'matches the formality of your meeting.',
  },
  {
    icon: '🧩',
    title: 'Open, swappable, extensible',
    body:
      'The pipeline is three layers: Rust shell, React UI, Python audio sidecar. Swap ' +
      'any model, add a new language, fork the repo — MIT licensed.',
  },
];
---

<BaseLayout title={title} description={description}>
  <article class="wrap container section">
    <header class="page-head">
      <span class="hig-label">Features</span>
      <h1>Every detail, tuned for real meetings.</h1>
      <p class="lede">
        SyncSpeak is not a wrapper around a generic translation API. Every stage of the
        pipeline is engineered around the specific failure modes of voice translation
        in corporate meetings — mic contention, first-syllable clipping, pronoun drift,
        self-talk loops, and perceived latency.
      </p>
    </header>

    <section class="features" aria-label="Feature list">
      {
        features.map((f) => (
          <article class="glass-card feat">
            <div class="icon" aria-hidden="true">{f.icon}</div>
            <h2>{f.title}</h2>
            <p>{f.body}</p>
          </article>
        ))
      }
    </section>

    <footer class="page-cta">
      <DownloadButton label="Download for" />
      <a href="/how-it-works" class="ghost-btn">Pipeline deep dive →</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .wrap { max-width: 1100px; }
  .page-head {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }
  .page-head h1 { margin: var(--space-m) 0 var(--space-l); }
  .lede {
    max-width: 64ch;
    margin: 0 auto;
    font-size: 1.125rem;
    color: var(--vibrant-label);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
  }
  .feat {
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }
  .feat h2 { font-size: 1.1875rem; }
  .icon { font-size: 1.75rem; margin-bottom: var(--space-s); }

  .page-cta {
    margin-top: var(--space-3xl);
    display: flex;
    gap: var(--space-m);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .features { grid-template-columns: 1fr; }
  }
  @media (min-width: 901px) and (max-width: 1100px) {
    .features { grid-template-columns: repeat(2, 1fr); }
  }
</style>
